# ── Percorsi ──────────────────────────────────────────────────────────────────
# Lascia vuoto per usare il default relativo alla posizione dello script
TRADING_BOT_DIR=C:\TradingBot

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Origins permessi per CORS (url del frontend, separati da virgola)
# Esempio: https://mio-bot.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Cifratura ─────────────────────────────────────────────────────────────────
# Chiave Fernet base64 (generata da setup.ps1, NON modificare manualmente)
# Per generarne una: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Chiave segreta per firmare i JWT (min. 32 caratteri casuali)
# Per generarne una: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# Imposta "true" in produzione HTTPS per marcare i cookie come Secure
COOKIE_SECURE=false

# ── Gemini AI — parsing segnali ───────────────────────────────────────────────
# Ottieni la chiave su: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Model ID esatti — verifica su https://ai.google.dev/gemini-api/docs/models
GEMINI_FLASH_MODEL=gemini-2.5-flash-preview
GEMINI_PRO_MODEL=gemini-2.5-pro-preview

# ── Trading ───────────────────────────────────────────────────────────────────
# Lot size di default se il segnale non specifica un volume
DEFAULT_LOT_SIZE=0.01

# ── Stripe Pagamenti ──────────────────────────────────────────────────────────
# Chiave segreta Stripe (sk_live_... in produzione, sk_test_... in sviluppo)
STRIPE_SECRET_KEY=
# Segreto per la verifica dei webhook Stripe (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Price ID Stripe per ogni piano (crea i piani su dashboard.stripe.com/products)
STRIPE_PRICE_CORE=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=
# URL base del frontend — usato per costruire success_url e cancel_url
NEXT_PUBLIC_BASE_URL=http://localhost:3000
