# ── Percorsi ──────────────────────────────────────────────────────────────────
# Lascia vuoto per usare il default relativo alla posizione dello script
TRADING_BOT_DIR=C:\TradingBot

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Origins permessi per CORS (url del frontend, separati da virgola)
# Esempio: https://mio-bot.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Cifratura ─────────────────────────────────────────────────────────────────
# Chiave Fernet base64 (generata da setup.ps1, NON modificare manualmente)
# Per generarne una: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
